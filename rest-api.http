POST http://localhost:8081/api/direct-comparisons/rest-api
Content-Type: application/json

{
  "sourceOneUrl": "http://localhost:8080/rjp/query?connection=EXAMPLE_DB_1&sqlQuery=select * from customer where id < 800",
  "sourceOneParams": {
    "authToken": "<SOURCE_API_TOKEN>",
    "recordsPath": "$",
    "primaryKeyField": "ID"
  },
  "sourceTwoUrl": "http://localhost:8080/rjp/query?connection=EXAMPLE_DB_2&sqlQuery=select * from customer where id < 8",
  "sourceTwoParams": {
    "authToken": "<TARGET_API_TOKEN>",
    "recordsPath": "$",
    "primaryKeyField": "ID"
  },
  "comparisonConfig": {
    "keyFields": [
      "ID"
    ],
    "fieldsToCompare": [
      "FIRST_NAME",
      "LAST_NAME"
    ],
    "ignoreCase": true,
    "ignoreWhitespace": true
  },
  "comparisonName": "Customer Data Comparison"
}

