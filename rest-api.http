GET http://localhost:8080/rjp/query?connection=EXAMPLE_DB&sqlQuery=select%20*%20from%20customer%20where%20id%3C800

###
POST http://localhost:8081/api/direct-comparisons/rest-api
Content-Type: application/json

{
  "sourceOneUrl": "http://localhost:8081/rjp/query?connection=EXAMPLE_DB_1&sqlQuery=select%20*%20from%20customer%20where%20id%3C800",
  "sourceOneParams": {
    "authToken": "<SOURCE_API_TOKEN>",
    "headers": {"X-API-Version": "1.0"},
    "recordsPath": "$"
  },
  "sourceTwoUrl": "http://localhost:8081/rjp/query?connection=EXAMPLE_DB_2&sqlQuery=select%20*%20from%20customer%20where%20id%3C800",
  "sourceTwoParams": {
    "authToken": "<TARGET_API_TOKEN>",
    "headers": {"Accept": "application/json"},
    "recordsPath": "$"
  },
  "comparisonConfig": {
    "keyFields": ["id"],
    "fieldsToCompare": ["name", "email", "status"],
    "ignoreCase": true
  }
}

